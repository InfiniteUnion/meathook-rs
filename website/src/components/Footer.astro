---
---
<footer class="border-t border-zinc-800/60 py-14 px-6">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
    <!-- Brand -->
    <div class="flex items-center gap-4">
      <img src="/logo.png" alt="meathook" class="h-9 w-auto opacity-75" />
      <div>
        <p class="text-zinc-200 font-semibold text-sm">meathook</p>
        <p class="text-zinc-600 text-xs mt-0.5">Apache-2.0 / MIT</p>
      </div>
    </div>

    <!-- Links -->
    <div class="flex flex-wrap items-center gap-6 text-sm text-zinc-500">
      <a
        href="https://crates.io/crates/meathook-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-300 transition-colors">crates.io</a
      >
      <a
        href="https://docs.rs/meathook-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-300 transition-colors">docs.rs</a
      >
      <a
        href="https://github.com/zeon256/meathook-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-300 transition-colors">GitHub</a
      >
      <a
        href="https://github.com/zeon256/satay-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-300 transition-colors">satay-rs</a
      >
    </div>
  </div>

  <div class="max-w-6xl mx-auto mt-10 pt-6 border-t border-zinc-800/40">
    <p class="text-zinc-700 text-xs" style="font-family: var(--font-mono)">
      Built on the <a
        href="https://github.com/zeon256/satay-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-500 transition-colors">satay-rs</a
      > sans-IO action model. HuggingFace datasets (parquet) supported as a terminal sink out of the box.
    </p>
  </div>
</footer>
