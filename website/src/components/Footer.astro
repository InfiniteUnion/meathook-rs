---
const year = new Date().getFullYear();
const links = [
  { label: 'crates.io', href: 'https://crates.io/crates/meathook-rs' },
  { label: 'docs.rs', href: 'https://docs.rs/meathook-rs' },
  { label: 'github', href: 'https://github.com/InfiniteUnion/meathook-rs' },
];
---

<footer class="border-t hairline">
  <div class="mx-auto max-w-[84rem] px-6 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-[26rem]">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="" class="h-7 w-7 object-contain" width="28" height="28" />
          <span class="font-mono text-sm text-ink">meathook</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-ink-dim">
          A library-first base for long-running data collection jobs.
        </p>
      </div>

      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="font-mono text-xs text-ink-dim transition-colors hover:text-accent"
              rel="noopener"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t hairline pt-6 font-mono text-xs text-ink-faint sm:flex-row sm:items-center sm:justify-between">
      <p>Apache-2.0 OR MIT &middot; Rust 2024 edition</p>
      <p>&copy; {year} meathook-rs</p>
    </div>
  </div>
</footer>
