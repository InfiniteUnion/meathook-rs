---
const links = [
  { label: 'docs.rs', href: 'https://docs.rs/meathook-rs' },
  { label: 'crates.io', href: 'https://crates.io/crates/meathook-rs' },
  { label: 'github', href: 'https://github.com/InfiniteUnion/meathook-rs' },
];
---

<header class="border-b hairline">
  <nav class="mx-auto flex max-w-[84rem] items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-3" aria-label="meathook home">
      <img src="/logo.png" alt="" class="h-8 w-8 object-contain" width="32" height="32" />
      <span class="font-mono text-sm tracking-tight text-ink">meathook</span>
    </a>
    <ul class="flex items-center gap-7">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="font-mono text-xs tracking-wide text-ink-dim transition-colors hover:text-accent"
            rel="noopener"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
