---
const links = [
  { label: 'Sinks', href: '#sinks' },
  { label: 'How it works', href: '#stack' },
  { label: 'Durability', href: '#durability' },
  { label: 'Example', href: '#example' },
];
---

<header class="sticky top-0 z-40 border-b border-line bg-canvas/90 backdrop-blur-sm">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-6 px-5 lg:px-8">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img src="/logo.png" alt="" class="h-8 w-auto" width="32" height="32" />
      <span class="text-sm font-semibold tracking-tight text-ink">meathook</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-muted transition-colors hover:text-ink"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <a
        href="https://docs.rs/meathook-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm text-muted transition-colors hover:text-ink sm:inline"
      >
        Docs
      </a>
      <a
        href="https://crates.io/crates/meathook-rs"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded bg-hook px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-600 active:scale-[0.98]"
      >
        Install
      </a>
    </div>
  </nav>
</header>
