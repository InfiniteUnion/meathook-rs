---
---

<section class="relative overflow-hidden border-b border-line">
  <div
    class="pointer-events-none absolute -right-24 top-0 h-[480px] w-[480px] opacity-[0.08]"
    style="background: radial-gradient(circle, #ef4444 0%, transparent 68%)"
    aria-hidden="true"
  />

  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:gap-16 lg:px-8 lg:py-20">
    <div>
      <p class="reveal mb-5 font-mono text-xs text-hook">library-first data collection</p>

      <h1 class="reveal max-w-xl text-4xl font-semibold leading-[1.08] tracking-tight text-ink md:text-5xl lg:text-[3.25rem]">
        Poll APIs. Buffer windows.
        <span class="text-hook">Ship anywhere.</span>
      </h1>

      <p class="reveal mt-5 max-w-md text-base leading-relaxed text-muted">
        Wire collectors and sinks in Rust. Every tick fsyncs to disk before ingest returns.
        Panics respawn. SIGTERM drains the stack.
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3">
        <a
          href="https://crates.io/crates/meathook-rs"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded bg-hook px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-red-800 active:scale-[0.98]"
        >
          crates.io
        </a>
        <a
          href="https://github.com/zeon256/meathook-rs"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded border border-line-strong px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-muted active:scale-[0.98]"
        >
          Source
        </a>
      </div>
    </div>

    <div class="reveal relative flex justify-center lg:justify-end">
      <div class="relative flex flex-col items-center">
        <div
          class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-64 w-64 -translate-x-1/2 -translate-y-1/2 opacity-40"
          style="background: radial-gradient(circle, rgba(239,68,68,0.2) 0%, transparent 70%)"
          aria-hidden="true"
        />
        <img
          src="/logo.png"
          alt="meathook logo"
          class="relative h-auto w-60 lg:w-72"
          width="288"
          height="288"
        />
        <p class="mt-5 font-mono text-[11px] text-hook">pluggable terminal sinks</p>
      </div>
    </div>
  </div>
</section>
