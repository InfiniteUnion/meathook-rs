---
import Reveal from './Reveal.astro';

const rows = [
  {
    failure: 'SIGKILL / OOM-kill',
    what: 'leftover segments replayed on next start',
    lost: '≤ 1 torn record',
    severity: 'warn',
  },
  {
    failure: 'Task panic',
    what: 'supervisor respawns the pipeline from its factory',
    lost: 'none',
    severity: 'ok',
  },
  {
    failure: 'Sink outage (HF 5xx)',
    what: 'segments accumulate on disk, retried each firing',
    lost: 'none',
    severity: 'ok',
  },
  {
    failure: 'Graceful SIGTERM',
    what: 'runtime drains every sink stack before exit',
    lost: 'none',
    severity: 'ok',
  },
  {
    failure: 'Disk lost',
    what: 'spool gone — use a PVC on k8s',
    lost: 'everything unflushed',
    severity: 'bad',
  },
];
---

<section class="py-28 px-6 border-t border-zinc-800/60">
  <div class="max-w-6xl mx-auto">
    <Reveal>
      <div class="mb-16">
        <span class="text-red-600 text-xs font-mono tracking-[0.2em] uppercase">Durability</span>
        <h2 class="text-5xl font-bold mt-2 text-zinc-50">Failure modes</h2>
        <p class="text-zinc-500 mt-4 max-w-xl text-lg leading-relaxed">
          <code
            class="text-zinc-300 bg-zinc-800/80 px-1.5 py-0.5 rounded text-sm"
            style="font-family: var(--font-mono)">DiskSpool</code
          > appends records as JSON lines to an fsynced segment file before
          <code
            class="text-zinc-300 bg-zinc-800/80 px-1.5 py-0.5 rounded text-sm"
            style="font-family: var(--font-mono)">ingest</code
          >
          returns. Segments are deleted only after the downstream sink accepted them. Storage paths
          are deterministic, so replays are idempotent.
        </p>
      </div>
    </Reveal>

    <Reveal delay={60}>
      <div class="overflow-x-auto rounded-xl border border-zinc-800">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-zinc-800 bg-zinc-900/60">
              <th
                class="text-left py-4 px-6 text-zinc-500 font-medium text-sm tracking-wide uppercase"
                >Failure</th
              >
              <th
                class="text-left py-4 px-6 text-zinc-500 font-medium text-sm tracking-wide uppercase"
                >What happens</th
              >
              <th
                class="text-left py-4 px-6 text-zinc-500 font-medium text-sm tracking-wide uppercase"
                >Data lost</th
              >
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row, i) => (
                <tr
                  class:list={[
                    'border-b border-zinc-800/60 hover:bg-zinc-800/20 transition-colors',
                    i === rows.length - 1 ? 'border-b-0' : '',
                  ]}
                >
                  <td
                    class="py-5 px-6 text-zinc-300 text-sm"
                    style="font-family: var(--font-mono)"
                  >
                    {row.failure}
                  </td>
                  <td class="py-5 px-6 text-zinc-400 text-lg">{row.what}</td>
                  <td class="py-5 px-6">
                    <span
                      class:list={[
                        'inline-flex items-center gap-2 text-sm font-medium',
                        row.severity === 'ok'
                          ? 'text-emerald-500'
                          : row.severity === 'warn'
                            ? 'text-amber-500'
                            : 'text-zinc-500',
                      ]}
                      style="font-family: var(--font-mono)"
                    >
                      {row.severity === 'ok' && (
                        <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block flex-shrink-0" />
                      )}
                      {row.severity === 'warn' && (
                        <span class="w-2 h-2 rounded-full bg-amber-500 inline-block flex-shrink-0" />
                      )}
                      {row.severity === 'bad' && (
                        <span class="w-2 h-2 rounded-full bg-zinc-600 inline-block flex-shrink-0" />
                      )}
                      {row.lost}
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </Reveal>
  </div>
</section>
