---
import { highlightCode } from '../lib/highlight.mjs';

const code = `use std::{time::Duration, env};

use meathook::{FlushPolicy, HfSink, Meathook, Pipeline, SatayCollector, SinkExt as _};
use satay_reqwest::ReqwestActionExt as _;
use reqwest::Client;

#[tokio::main]
async fn main() -> Result<(), meathook::runtime::RuntimeError> {
    let client = Client::new();
    let token = env::var("HF_TOKEN").expect("HF_TOKEN must be set");

    Meathook::builder()
        .pipeline(move || {
            let api = nea_rs::Api::new();
            let collector = SatayCollector::new(
                "air_temperature",
                client.clone(),
                move |client| {
                    let api = api.clone();
                    async move { api.air_temperature().send_with(&client).await }
                },
                |response| flatten(response),
            );

            // Durable stack: every tick is fsynced to disk before ingest
            // returns; hourly windows land on HF as parquet.
            let sink = HfSink::new(client.clone(), "you/your-dataset", token.clone())
                .spooled("/var/lib/meathook/spool/air_temperature", FlushPolicy::hourly());

            Pipeline::new(collector, sink, Duration::from_secs(60))
                .with_key_fn(|r: &MyRecord| (r.station_id.clone(), r.timestamp.clone()))
        })
        .run()
        .await
}`;

const highlighted = await highlightCode('rust', code);
const lines = highlighted.split('\n');
---

<section class="border-t hairline">
  <div class="mx-auto max-w-[84rem] px-6 py-20 md:py-28">
    <p class="eyebrow mb-5">wire it in code</p>
    <h2 class="font-display text-4xl leading-tight tracking-[-0.01em] text-ink md:text-5xl">
      Two traits, composed like tower layers.
    </h2>
    <p class="mt-6 max-w-[44rem] text-lg leading-relaxed text-ink-dim">
      There is no YAML plugin system. You implement&nbsp;
      <code class="font-mono text-sm text-ink">Collector</code> and&nbsp;
      <code class="font-mono text-sm text-ink">Sink</code>, and sinks compose
      with the same&nbsp;<code class="font-mono text-sm text-ink">.spooled()</code>
      &nbsp;combinator you'd expect from tower.
    </p>

    <div class="group relative mt-10 overflow-x-auto rounded-sm border hairline bg-surface">
      <button
        type="button"
        data-copy-code
        data-raw-code={code}
        aria-label="Copy code"
        class="absolute right-3 top-3 z-10 inline-flex items-center justify-center leading-none rounded-sm border hairline bg-ground p-1.5 text-ink-faint transition-colors hover:text-accent"
      >
        <span class="copy-icon-slot" aria-hidden="true">
          <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><rect x="8" y="8" width="10" height="10"></rect><path d="M6 16H4V4h12v2"></path></svg>
          <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square" stroke-linejoin="miter"><path d="M5 12.5 10 17 19 7"></path></svg>
        </span>
      </button>
      <pre class="px-5 py-5 font-mono text-[0.8125rem] leading-[1.65]" data-arborium data-arborium-language="rust"><code data-code-block>{lines.map((line, i) => (
        <span class="code-line"><span class="lineno">{i + 1}</span><span class="code-text" set:html={line || ' '} /></span>
      ))}</code></pre>
    </div>

    <p class="mt-6 font-mono text-xs text-ink-faint">
      records are plain structs &mdash;&nbsp;
      <code class="text-ink-dim">#[derive(Serialize, Deserialize)]</code>
      &nbsp;is all the parquet encoder needs
    </p>
  </div>
</section>

<script>
  const btn = document.querySelector('[data-copy-code]') as HTMLButtonElement | null;
  if (btn) {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.rawCode || '';
      try {
        await navigator.clipboard.writeText(text);
        btn.setAttribute('data-copied', 'true');
        window.setTimeout(() => btn.removeAttribute('data-copied'), 1400);
      } catch {
        // noop
      }
    });
  }
</script>

<style is:global>
  .code-line {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    color: var(--color-ink-dim);
  }
  .lineno {
    flex: 0 0 1.5rem;
    width: 1.5rem;
    text-align: right;
    color: color-mix(in srgb, var(--color-ink-faint) 60%, transparent);
    user-select: none;
  }
  .code-text { white-space: pre; }

  /* copy/check icon swap — same pattern as hero */
  .copy-icon-slot {
    display: inline-grid;
    width: 0.875rem;
    height: 0.875rem;
    color: inherit;
  }
  .copy-icon-slot svg {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    transition: opacity 150ms ease, transform 150ms ease;
  }
  .copy-icon { opacity: 1; transform: scale(1); }
  .check-icon { opacity: 0; transform: scale(0.75); }
  [data-copy-code][data-copied="true"] .copy-icon { opacity: 0; transform: scale(0.75); }
  [data-copy-code][data-copied="true"] .check-icon { opacity: 1; transform: scale(1); color: var(--color-accent); }
</style>
